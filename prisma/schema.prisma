generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  super_admin
  admin
  editor
}

model User {
  id           Int       @id @default(autoincrement())
  fullName     String
  email        String    @unique
  passwordHash String
  role         Role
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  podcasts     Podcast[]
  articles     Article[]
}

model Podcast {
  id             Int      @id @default(autoincrement())
  youtubeUrl     String
  youtubeVideoId String
  coverImageUrl  String?
  title          String
  description    String
  publishedAt    DateTime
  speakerName    String   @default("Cleansing Water Ministry")
  createdById    Int
  createdBy      User     @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([publishedAt])
  @@index([createdById])
}

model Article {
  id           Int       @id @default(autoincrement())
  coverImageUrl String?
  title        String
  description  String
  contentRaw   String    @db.Text
  authorName   String    @default("Cleansing Water Ministry")
  publishedAt  DateTime?
  createdById  Int
  createdBy    User      @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([publishedAt])
  @@index([createdById])
}
